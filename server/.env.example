# Firebase Admin SDK (from a service account JSON — never commit the JSON file itself)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the \n escape sequences literal; the app converts them to real newlines at runtime.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Server
PORT=4000
NODE_ENV=development

# Origin allowed to call this API (the deployed client URL in production)
CLIENT_ORIGIN=http://localhost:5173

# AES-256-GCM key used to encrypt per-project CMS credentials at rest (Section 9).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Webflow OAuth app credentials — optional. Without these, the "Sign in with
# Webflow" connection path returns a clear error and API Token connection
# still works fully (Section 4.3). Register an app at https://webflow.com/dashboard/apps
# The redirect URI is a single static URL (Webflow requires an exact match) —
# which project/user is connecting is carried in the OAuth `state` param, not the URL.
WEBFLOW_OAUTH_CLIENT_ID=
WEBFLOW_OAUTH_CLIENT_SECRET=
WEBFLOW_OAUTH_REDIRECT_URI=http://localhost:4000/api/projects/connect/oauth/callback

# --- Added in later phases (not yet read by any code) ---
# RESEND_API_KEY=
# EMAIL_FROM_ADDRESS=
